# URL du bridge Bumpify (API publique)
# IMPORTANT : doit correspondre EXACTEMENT au PORT défini dans le .env du bridge lui-même.
BRIDGE_URL=http://de-01.rrhosting.eu:7536

# Authentification Discord (next-auth)
# Client ID / Client Secret : Discord Developer Portal > ton application > OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Chaîne aléatoire longue, générée une fois (ex: openssl rand -base64 32)
NEXTAUTH_SECRET=
# URL publique exacte du site en production
NEXTAUTH_URL=https://zyntra.dpdns.org
